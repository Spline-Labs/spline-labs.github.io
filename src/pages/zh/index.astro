---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n/translations';

const t = translations.zh;
---

<Layout title="首页" lang="zh">
  <section class="hero">
    <canvas id="spline-canvas" class="hero-canvas"></canvas>
    <div class="container hero-content">
      <h1 class="hero-title">{t.home.hero.title}</h1>
      <p class="hero-subtitle">{t.home.hero.subtitle}</p>
      <p class="hero-description">{t.home.hero.description}</p>
      <div class="hero-actions">
        <a href="/zh/research" class="btn btn-primary">探索研究</a>
        <a href="/zh/contact" class="btn btn-secondary">联系我们</a>
      </div>
    </div>
  </section>

  <section class="section about-preview">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <h2 class="section-title" style="text-align: left;">{t.home.about.title}</h2>
          <p>{t.home.about.description}</p>
          <a href="/zh/about" class="about-link">
            了解更多
            <svg viewBox="0 0 24 24" width="20" height="20">
              <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </a>
        </div>
        <div class="about-visual">
          <svg viewBox="0 0 200 150" class="about-spline">
            <path class="spline-line" d="M20 130 C 40 80, 60 120, 80 60 S 120 100, 140 40 S 180 80, 180 80"/>
            <circle cx="20" cy="130" r="4" class="spline-point"/>
            <circle cx="80" cy="60" r="4" class="spline-point"/>
            <circle cx="140" cy="40" r="4" class="spline-point"/>
            <circle cx="180" cy="80" r="4" class="spline-point"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <section class="section features">
    <div class="container">
      <h2 class="section-title">{t.home.features.title}</h2>
      <div class="grid grid-4">
        {t.home.features.items.map((item, index) => (
          <div class={`card feature-card animate-fade-in animate-delay-${index + 1}`}>
            <div class="feature-icon">
              {index === 0 && (
                <svg viewBox="0 0 24 24" width="32" height="32">
                  <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
              {index === 1 && (
                <svg viewBox="0 0 24 24" width="32" height="32">
                  <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
              {index === 2 && (
                <svg viewBox="0 0 24 24" width="32" height="32">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M22 4L12 14.01l-3-3" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
              {index === 3 && (
                <svg viewBox="0 0 24 24" width="32" height="32">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2" fill="none"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
            </div>
            <h3 class="feature-title">{item.title}</h3>
            <p class="feature-description">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section research-preview">
    <div class="container">
      <h2 class="section-title">{t.home.research.title}</h2>
      <div class="grid grid-3">
        {t.research.areas.slice(0, 3).map((area, index) => (
          <div class={`card research-card animate-fade-in animate-delay-${index + 1}`}>
            <h3 class="research-title">{area.title}</h3>
            <p class="research-description">{area.description.substring(0, 120)}...</p>
            <div class="research-tags">
              {area.keywords.slice(0, 2).map((keyword) => (
                <span class="tag">{keyword}</span>
              ))}
            </div>
            <a href="/zh/research" class="research-link">了解更多 →</a>
          </div>
        ))}
      </div>
      <div style="text-align: center; margin-top: 32px;">
        <a href="/zh/research" class="btn btn-secondary">{t.home.research.viewAll}</a>
      </div>
    </div>
  </section>

  <section class="section publications-preview">
    <div class="container">
      <h2 class="section-title">{t.home.publications.title}</h2>
      <div class="publications-list">
        {t.publications.papers.slice(0, 3).map((paper, index) => (
          <div class={`card publication-card animate-fade-in animate-delay-${index + 1}`}>
            <div class="publication-header">
              <span class="publication-year">{paper.year}</span>
              <span class="publication-journal">{paper.journal}</span>
            </div>
            <h3 class="publication-title">{paper.title}</h3>
            <p class="publication-authors">{paper.authors}</p>
          </div>
        ))}
      </div>
      <div style="text-align: center; margin-top: 32px;">
        <a href="/zh/publications" class="btn btn-secondary">{t.home.publications.viewAll}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-bg) 0%, var(--color-border) 100%);
  }
  
  .hero-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0.5;
  }
  
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
  }
  
  .hero-title {
    font-size: 4rem;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  
  .hero-subtitle {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 16px;
  }
  
  .hero-description {
    font-size: 1.125rem;
    color: var(--color-text-light);
    margin-bottom: 32px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  
  .about-preview {
    background-color: var(--color-bg-card);
  }
  
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  
  .about-text p {
    color: var(--color-text-light);
    margin-bottom: 24px;
    font-size: 1.125rem;
  }
  
  .about-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    color: var(--color-accent);
  }
  
  .about-link:hover {
    gap: 12px;
  }
  
  .about-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .about-spline {
    width: 100%;
    max-width: 300px;
  }
  
  .spline-line {
    stroke: var(--color-primary);
    stroke-width: 3;
    fill: none;
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    animation: drawSpline 3s ease forwards;
  }
  
  .spline-point {
    fill: var(--color-accent);
    opacity: 0;
    animation: fadeIn 0.5s ease forwards;
    animation-delay: 2s;
  }
  
  @keyframes drawSpline {
    to {
      stroke-dashoffset: 0;
    }
  }
  
  .feature-card {
    text-align: center;
  }
  
  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    color: #fff;
    margin-bottom: 16px;
  }
  
  .feature-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 8px;
  }
  
  .feature-description {
    color: var(--color-text-light);
    font-size: 0.875rem;
  }
  
  .research-card {
    position: relative;
  }
  
  .research-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--color-primary);
  }
  
  .research-description {
    color: var(--color-text-light);
    font-size: 0.875rem;
    margin-bottom: 16px;
  }
  
  .research-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }
  
  .tag {
    display: inline-block;
    padding: 4px 12px;
    background-color: var(--color-border);
    color: var(--color-text-light);
    font-size: 0.75rem;
    border-radius: var(--radius-sm);
  }
  
  .research-link {
    font-weight: 600;
    font-size: 0.875rem;
  }
  
  .publications-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  
  .publication-card {
    padding: 24px;
  }
  
  .publication-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 12px;
  }
  
  .publication-year {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-accent);
  }
  
  .publication-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--color-text);
  }
  
  .publication-authors {
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin-bottom: 4px;
  }
  
  .publication-journal {
    font-size: 0.875rem;
    color: var(--color-primary);
    font-weight: 500;
  }
  
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.5rem;
    }
    
    .hero-subtitle {
      font-size: 1.25rem;
    }
    
    .about-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    
    .publication-card {
      padding-left: 24px;
      padding-top: 60px;
    }
    
    .publication-year {
      top: 16px;
      left: 16px;
    }
  }
</style>

<script>
  const canvas = document.getElementById('spline-canvas') as HTMLCanvasElement;
  const ctx = canvas?.getContext('2d');
  
  if (ctx && canvas) {
    const resizeCanvas = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight * 0.8;
    };
    
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);
    
    const controlPoints = [
      { x: 100, y: 150 },
      { x: 300, y: 80 },
      { x: 500, y: 200 },
      { x: 700, y: 100 },
      { x: 900, y: 180 },
      { x: 1100, y: 120 },
      { x: 1300, y: 160 },
    ];
    
    let offset = 0;
    
    const drawSpline = () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      
      ctx.strokeStyle = getComputedStyle(document.documentElement).getPropertyValue('--color-primary').trim() || '#1a365d';
      ctx.lineWidth = 2;
      ctx.globalAlpha = 0.3;
      
      for (let j = 0; j < 5; j++) {
        ctx.beginPath();
        const yOffset = j * 60;
        
        for (let i = 0; i < controlPoints.length; i++) {
          const x = controlPoints[i].x + offset + j * 40;
          const y = controlPoints[i].y + yOffset + Math.sin((i + offset * 0.01) * 0.5) * 20;
          
          if (i === 0) {
            ctx.moveTo(x % (canvas.width + 200), y);
          } else {
            ctx.lineTo(x % (canvas.width + 200), y);
          }
        }
        ctx.stroke();
      }
      
      offset += 1;
      requestAnimationFrame(drawSpline);
    };
    
    drawSpline();
  }
</script>
