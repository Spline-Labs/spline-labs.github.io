---
import '../styles/global.css';

interface Props {
  title: string;
  lang?: string;
}

const { title, lang = 'en' } = Astro.props;
import { translations, defaultLang } from '../i18n/translations';

const t = translations[lang as keyof typeof translations] || translations[defaultLang];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Spline-Labs - Advancing Spline Theory for Modern Engineering">
  <title>{title} | Spline-Labs</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <header class="header">
    <div class="container header-inner">
      <a href={`/${lang === 'en' ? '' : 'zh/'}`} class="logo">
        <svg class="logo-icon" viewBox="0 0 40 40" width="32" height="32">
          <path d="M5 30 C 10 10, 15 35, 20 20 S 30 10, 35 25" stroke="var(--color-accent)" stroke-width="3" fill="none" stroke-linecap="round"/>
          <circle cx="5" cy="30" r="3" fill="var(--color-primary)"/>
          <circle cx="20" cy="20" r="3" fill="var(--color-primary)"/>
          <circle cx="35" cy="25" r="3" fill="var(--color-primary)"/>
        </svg>
        <span>Spline-Labs</span>
      </a>
      
      <nav class="nav">
        <a href={`/${lang === 'en' ? '' : 'zh/'}`}>{t.nav.home}</a>
        <a href={`/${lang === 'en' ? 'about' : 'zh/about'}`}>{t.nav.about}</a>
        <a href={`/${lang === 'en' ? 'research' : 'zh/research'}`}>{t.nav.research}</a>
        <a href={`/${lang === 'en' ? 'publications' : 'zh/publications'}`}>{t.nav.publications}</a>
        <a href={`/${lang === 'en' ? 'resources' : 'zh/resources'}`}>{t.nav.resources}</a>
        <a href={`/${lang === 'en' ? 'contact' : 'zh/contact'}`}>{t.nav.contact}</a>
      </nav>
      
      <div class="header-actions">
        <button id="lang-toggle" class="lang-toggle" title="Toggle Language">
          {lang === 'en' ? '中文' : 'EN'}
        </button>
        <button id="theme-toggle" class="theme-toggle" title="Toggle Theme">
          <svg class="sun-icon" viewBox="0 0 24 24" width="20" height="20">
            <circle cx="12" cy="12" r="5" fill="currentColor"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <svg class="moon-icon" viewBox="0 0 24 24" width="20" height="20">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" fill="currentColor"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <div class="logo">
            <svg class="logo-icon" viewBox="0 0 40 40" width="28" height="28">
              <path d="M5 30 C 10 10, 15 35, 20 20 S 30 10, 35 25" stroke="var(--color-accent)" stroke-width="3" fill="none" stroke-linecap="round"/>
              <circle cx="5" cy="30" r="3" fill="var(--color-primary)"/>
              <circle cx="20" cy="20" r="3" fill="var(--color-primary)"/>
              <circle cx="35" cy="25" r="3" fill="var(--color-primary)"/>
            </svg>
            <span>Spline-Labs</span>
          </div>
          <p>{t.footer.description}</p>
        </div>
        <div class="footer-links">
          <a href={`/${lang === 'en' ? '' : 'zh/'}`}>{t.nav.home}</a>
          <a href={`/${lang === 'en' ? 'about' : 'zh/about'}`}>{t.nav.about}</a>
          <a href={`/${lang === 'en' ? 'research' : 'zh/research'}`}>{t.nav.research}</a>
          <a href={`/${lang === 'en' ? 'publications' : 'zh/publications'}`}>{t.nav.publications}</a>
          <a href={`/${lang === 'en' ? 'resources' : 'zh/resources'}`}>{t.nav.resources}</a>
          <a href={`/${lang === 'en' ? 'contact' : 'zh/contact'}`}>{t.nav.contact}</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>{t.footer.copyright}</p>
      </div>
    </div>
  </footer>

  <script>
    const themeToggle = document.getElementById('theme-toggle');
    const langToggle = document.getElementById('lang-toggle');
    
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme) {
      document.documentElement.setAttribute('data-theme', savedTheme);
    }
    
    themeToggle?.addEventListener('click', () => {
      const currentTheme = document.documentElement.getAttribute('data-theme');
      const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', newTheme);
      localStorage.setItem('theme', newTheme);
    });
    
    langToggle?.addEventListener('click', () => {
      const currentPath = window.location.pathname;
      if (currentPath.startsWith('/zh')) {
        window.location.href = currentPath.replace('/zh', '');
      } else {
        window.location.href = '/zh' + (currentPath === '/' ? '' : currentPath);
      }
    });
  </script>

  <style>
    .header {
      position: sticky;
      top: 0;
      background-color: var(--color-bg-card);
      border-bottom: 1px solid var(--color-border);
      z-index: 100;
      backdrop-filter: blur(10px);
      background-color: rgba(255, 255, 255, 0.9);
    }
    
    [data-theme="dark"] .header {
      background-color: rgba(27, 38, 59, 0.9);
    }
    
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
    }
    
    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--color-text);
    }
    
    .nav {
      display: flex;
      gap: 32px;
    }
    
    .nav a {
      color: var(--color-text-light);
      font-weight: 500;
      transition: color var(--transition-fast);
    }
    
    .nav a:hover {
      color: var(--color-accent);
    }
    
    .header-actions {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    
    .lang-toggle, .theme-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border: none;
      background: transparent;
      color: var(--color-text-light);
      cursor: pointer;
      border-radius: var(--radius-md);
      transition: all var(--transition-fast);
    }
    
    .lang-toggle:hover, .theme-toggle:hover {
      background-color: var(--color-border);
      color: var(--color-accent);
    }
    
    .sun-icon { display: none; }
    .moon-icon { display: block; }
    
    [data-theme="dark"] .sun-icon { display: block; }
    [data-theme="dark"] .moon-icon { display: none; }
    
    .footer {
      background-color: var(--color-footer-bg);
      color: #fff;
      padding: 48px 0 24px;
      margin-top: 80px;
    }
    
    .footer-content {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 32px;
    }
    
    .footer-brand {
      max-width: 300px;
    }
    
    .footer-brand .logo {
      color: #fff;
      margin-bottom: 12px;
    }
    
    .footer-brand p {
      opacity: 0.8;
      font-size: 0.875rem;
    }
    
    .footer-links {
      display: flex;
      flex-wrap: wrap;
      gap: 16px 32px;
    }
    
    .footer-links a {
      color: #fff;
      opacity: 0.8;
      font-size: 0.875rem;
    }
    
    .footer-links a:hover {
      opacity: 1;
      color: var(--color-accent);
    }
    
    .footer-bottom {
      padding-top: 24px;
      border-top: 1px solid rgba(255, 255, 255, 0.2);
    }
    
    .footer-bottom p {
      font-size: 0.875rem;
      opacity: 0.6;
      text-align: center;
    }
    
    @media (max-width: 768px) {
      .header-inner {
        height: 60px;
      }
      
      .nav {
        display: none;
      }
      
      .footer-content {
        flex-direction: column;
        gap: 24px;
      }
    }
  </style>
</body>
</html>
